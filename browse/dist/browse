#!/bin/sh
# gstack browse launcher (source mode).
#
# Replaces the prebuilt single-file binary. The locally-available bun
# (1.3.12) produces unsigned arm64 executables that macOS SIGKILLs, and
# `codesign` rejects bun's single-file format — so we run the CLI from
# source instead. The daemon + terminal-agent already run from source on
# macOS (`bun run server.ts`), so this keeps the whole stack on one code
# path and lets local source edits (named multi-instance support) take
# effect with no rebuild/signing step.
#
# To restore the prebuilt binary, reinstall gstack (its release ships a
# correctly-signed browse binary).
exec bun run "$(cd "$(dirname "$0")/../src" && pwd)/cli.ts" "$@"
